# API Configuration
NEXT_PUBLIC_API_URL=https://dispatch-tickets-api.onrender.com/v1

# Support Portal Configuration (for /support page)
DISPATCH_SUPPORT_BRAND_ID=ws_xxx  # Brand ID for Dispatch Tickets internal support
DISPATCH_API_KEY=                  # API key with access to support brand (server-side only)

# Clerk (Phase 1c — admin dual-mode login)
# Public key — safe to expose in client bundle. Get from Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Server-side secret. Used by clerkMiddleware() in proxy.ts and by server actions.
CLERK_SECRET_KEY=
# Where Clerk redirects users that hit a protected route while signed out.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
# Marketing site owns the signup form, so we point at it (cross-origin redirect is fine).
NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://dispatchtickets.com/signup/
# Where signed-in users land after returning from /login.
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
